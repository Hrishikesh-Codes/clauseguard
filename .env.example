# ── Backend (Railway) ─────────────────────────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Your Vercel frontend URL (set after deploying frontend)
# Example: https://clauseguard.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Your Railway backend URL (set after deploying backend)
# Example: https://clauseguard-production.up.railway.app
VITE_API_URL=https://your-backend.up.railway.app
